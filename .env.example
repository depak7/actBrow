# actbrow backend configuration — copy to a local env file / set in your environment.
# The committed application.properties reads these via ${VAR:default}. Never commit real secrets.

# --- Database (PostgreSQL) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/actbrow
SPRING_DATASOURCE_USERNAME=actbrow
SPRING_DATASOURCE_PASSWORD=actbrow

# --- Model provider (OpenAI-compatible, e.g. OpenRouter). Optional for local Claude-CLI proxy. ---
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api
# OPENAI_CHAT_MODEL=anthropic/claude-sonnet-4

# --- Google OAuth (login). Required for real sign-in; leave blank to disable. ---
GOOGLE_OAUTH_CLIENT_ID=

# --- CORS: comma-separated origins allowed to call the API ---
ACTBROW_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Signup/waitlist email notifications (SMTP, e.g. Gmail app password) ---
SIGNUP_NOTIFY_ENABLED=false
SIGNUP_NOTIFY_RECIPIENT=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
